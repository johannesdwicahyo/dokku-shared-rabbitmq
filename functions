#!/usr/bin/env bash
# Shared helpers for shared-rabbitmq. Sourced — never executed directly.
set -euo pipefail

generate_password() {
  # 16 random bytes -> 32 hex chars. Available everywhere; no openssl dep.
  od -An -tx1 -N16 /dev/urandom | tr -d ' \n'
}

validate_name() {
  local name="${1:-}"
  [[ -n "$name" ]] || return 1
  [[ "$name" =~ $PLUGIN_NAME_REGEX ]] || return 1
}

service_exists() {
  local name="$1"
  [[ -d "$PLUGIN_DATA_ROOT/$name" ]]
}

service_list() {
  [[ -d "$PLUGIN_DATA_ROOT" ]] || return 0
  local d
  for d in "$PLUGIN_DATA_ROOT"/*/; do
    [[ -d "$d" ]] || continue
    local name="${d%/}"
    name="${name##*/}"
    [[ "$name" == .* ]] && continue
    # `_rabbitmqdata` is the container's data volume mount, not a tenant.
    # Anything starting with `_` is reserved for plugin internals.
    [[ "$name" == _* ]] && continue
    printf '%s\n' "$name"
  done | sort
}

# Run rabbitmqctl against the shared container. rabbitmqctl authenticates to
# the local node via the Erlang cookie inside the container — no AMQP password
# needed. Executes inside the container via docker exec so the plugin never
# requires host-side rabbitmqctl and never depends on the container hostname
# resolving from the host.
run_rabbitmq_admin() {
  docker exec -i "$PLUGIN_CONTAINER_NAME" rabbitmqctl "$@"
}

service_dsn() {
  local name="$1"
  service_exists "$name" || { echo "service does not exist: $name" >&2; return 1; }
  local password
  password="$(<"$PLUGIN_DATA_ROOT/$name/PASSWORD")"
  printf 'amqp://%s:%s@%s:%s/%s\n' \
    "$name" "$password" "$PLUGIN_CONTAINER_NAME" "$PLUGIN_DB_PORT" "$name"
}

# Make sure the shared RabbitMQ container is up. Idempotent.
ensure_shared_container() {
  local existing
  existing="$(docker ps --filter "name=^${PLUGIN_CONTAINER_NAME}$" --format '{{.Names}}' || true)"
  if [[ -n "$existing" ]]; then
    return 0
  fi

  docker network create "$PLUGIN_NETWORK_NAME" >/dev/null 2>&1 || true

  # Queue durability + vhost/user/permission state live in the mounted volume
  # under /var/lib/rabbitmq. --memory caps the whole shared container.
  docker run --detach \
    --name "$PLUGIN_CONTAINER_NAME" \
    --network "$PLUGIN_NETWORK_NAME" \
    --restart always \
    --memory "$PLUGIN_MEMORY_LIMIT" \
    -v "${PLUGIN_DATA_ROOT}/_rabbitmqdata:/var/lib/rabbitmq" \
    "${PLUGIN_IMAGE}:${PLUGIN_IMAGE_VERSION}" \
    >/dev/null

  # docker run --detach returns before the broker finishes booting (~5-10s).
  # Block until the node is ready so the vhost/user ops that follow don't race
  # startup. await_startup blocks on its own; the retry loop also tolerates the
  # brief window where `docker exec` into the new container isn't ready yet.
  local tries=0
  until run_rabbitmq_admin await_startup >/dev/null 2>&1; do
    (( ++tries >= 60 )) && { echo "shared RabbitMQ did not become ready in time" >&2; return 1; }
    sleep 1
  done
}

service_create() {
  local name="$1"
  validate_name "$name" || { echo "invalid tenant name: $name" >&2; return 2; }
  if service_exists "$name"; then
    echo "service already exists: $name" >&2
    return 3
  fi
  ensure_shared_container

  local pw
  pw="$(generate_password)"

  # Write metadata BEFORE issuing rabbitmqctl ops — destroy can clean up if it fails.
  mkdir -p "$PLUGIN_DATA_ROOT/$name"
  printf '%s' "$pw" >"$PLUGIN_DATA_ROOT/$name/PASSWORD"
  : >"$PLUGIN_DATA_ROOT/$name/LINKS"
  chmod 600 "$PLUGIN_DATA_ROOT/$name/PASSWORD"

  run_rabbitmq_admin add_vhost "$name" >/dev/null
  run_rabbitmq_admin add_user "$name" "$pw" >/dev/null
  # Full configure/write/read WITHIN the vhost, nothing outside it.
  run_rabbitmq_admin set_permissions -p "$name" "$name" ".*" ".*" ".*" >/dev/null
}
