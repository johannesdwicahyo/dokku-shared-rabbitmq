#!/usr/bin/env bash
set -euo pipefail
[[ "${DOKKU_TRACE:-}" == "1" ]] && set -x

PLUGIN_ROOT="$(cd "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")" && pwd)"
# shellcheck source=config
source "$PLUGIN_ROOT/config"
# shellcheck source=functions
source "$PLUGIN_ROOT/functions"

shift || true

name="${1:-}"
msgs="${2:-}"

if [[ -z "$name" || -z "$msgs" ]]; then
  echo "usage: dokku $PLUGIN_COMMAND_PREFIX:set-quota <name> <msg_count>" >&2
  exit 2
fi

service_set_quota "$name" "$msgs"
echo "quota set: $name -> $msgs messages"
